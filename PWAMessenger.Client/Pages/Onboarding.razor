@page "/onboarding"
@attribute [Authorize]
@inject ApiService Api
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IConfiguration Config

@if (!awaitingNotification)
{
    <h2>Welcome!</h2>
    <p>What should we call you?</p>

    <input @bind="displayName" placeholder="Display Name" />
    <button @onclick="RegisterAsync" disabled="@loading">Continue</button>

    @if (error is not null)
    {
        <p style="color:red">@error</p>
    }
}
else
{
    <h2>One more thing</h2>
    <p>Enable notifications to receive match invites and messages.</p>
    <button @onclick="RequestNotificationsAsync">Allow Notifications</button>
    <button @onclick="SkipNotifications">Skip for Now</button>
}
