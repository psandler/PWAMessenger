@inject LoginService LoginSvc
@inject NavigationManager Navigation

<div>
    <h2>Sign In</h2>

    @if (error is not null)
    {
        <p style="color:red">@error</p>
    }

    <input type="email" @bind="email" placeholder="your@email.com" />
    <button @onclick="HandleLoginAsync" disabled="@loading">Continue</button>
</div>
